# ─────────────────────────────────────────────────────────────
# Comunidade VIP · DVP — variáveis de ambiente
# Copie para .env.local e preencha quando o projeto Supabase existir.
# ─────────────────────────────────────────────────────────────

# Supabase (projeto ainda não criado — preencher depois)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app (usada nos links dos e-mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (envio do código de login)
RESEND_API_KEY=
RESEND_FROM=Comunidade VIP DVP <contato@atualizacoes.crmmultimeta.com.br>

# Hotmart — token do webhook (Configurações do produto > Webhook/Postback)
HOTMART_HOTTOK=

# Janela de liberação após a compra (dias). Padrão: 7 (janela de reembolso).
ACCESS_WAITING_PERIOD_DAYS=7
